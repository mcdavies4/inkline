# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Meta Cloud API (WhatsApp)
WHATSAPP_ACCESS_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_VERIFY_TOKEN=inkline-verify-CHANGE-ME

# App
APP_BASE_URL=https://inkline.yourdomain.com
# Simple shared secret for the request-creation API (v1 auth)
INKLINE_API_KEY=CHANGE-ME-long-random-string

# Webhook signature verification (Meta App Dashboard → App settings → Basic → App secret)
META_APP_SECRET=

# Production templates (names as approved in Meta) + landing CTA number
WHATSAPP_TEMPLATE_SIGNATURE_REQUEST=signature_request
WHATSAPP_TEMPLATE_SIGNED_COPY=signed_copy_ready
WHATSAPP_TEMPLATE_LANG=en
NEXT_PUBLIC_WHATSAPP_NUMBER=447700900000

# AI document summary (optional — omit to disable summaries)
ANTHROPIC_API_KEY=sk-ant-...

# Reminders cron protection (Vercel Cron sends this automatically if set as CRON_SECRET)
CRON_SECRET=CHANGE-ME-random-string

# Stripe subscription (UK senders). Flutterwave (Nigeria) added in a later pass.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_MONTHLY=price_...       # $9/mo recurring price
STRIPE_PRICE_ANNUAL=price_...        # $90/yr recurring price
STRIPE_LABEL_MONTHLY=$9/month
STRIPE_LABEL_ANNUAL=$90/year (2 months free)
STRIPE_WEBHOOK_SECRET=whsec_...      # from the Stripe webhook endpoint

# Admin stats: your own WhatsApp number (digits only) for the ADMIN bot command
ADMIN_PHONE=447876135951
